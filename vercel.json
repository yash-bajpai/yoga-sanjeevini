{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/yoga-details", "dest": "/yoga-details.html" },
    { "src": "/instructor", "dest": "/instructor.html" },
    { "src": "/faq", "dest": "/faq.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
